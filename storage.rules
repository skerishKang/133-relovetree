rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared tree assets only: public read for images/videos already embedded in public trees.
    match /users/{userId}/trees/{allPaths=**} {
      allow read: if true;
    }

    // User specific folder: Only the user can write to their own folder
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
