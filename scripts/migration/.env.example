# .env.example
# 프로젝트 루트 또는 scripts/migration 디렉토리에 .env 파일로 복사하여 사용하세요.

# 1. Postgres 데이터베이스 연결 URL
# 예: Supabase, Neon, 로컬 Postgres 등
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/relovetree

# 2. Firebase Admin SDK 인증 (절대 경로 혹은 상대 경로)
# Firebase 콘솔 -> 프로젝트 설정 -> 서비스 계정 -> 새 비공개 키 생성에서 다운로드
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# 3. Netlify (또는 기타 배포 환경)에서 설정해야 할 운영 변수 예시
# (Netlify 대시보드 -> Site Settings -> Environment variables 에 등록)
# DATABASE_URL=postgresql://production_user:production_password@host:5432/relovetree
